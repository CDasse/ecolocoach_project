{% extends '_layouts/in_app.html.twig' %}

{% block title %}Mon parcours | EcoloCoach{% endblock %}

{% block header_title %}
    <h1 class="co2-counter-pill">
        <span class="co2-amount">
            {{ app.user.co2Impact | format_co2 }}
        </span>
        <span class="co2-label">
            de CO<sub>2</sub><br> économisés !</span>
    </h1>
{% endblock %}

{% block content %}
    <main>

        {% if is_path_completed %}
            <div class="success-card">
                <h2>Félicitations !</h2>
                <p>Tu as terminé l'intégralité de ton parcours éco-citoyen !</p>
            </div>
        {% else %}

            {% if user_current_level is not null %}
                <div class="level-header-card">
                    <div class="level-header-titles">
                        <h2>Niveau {{ user_current_level.sequenceNumber }}</h2>
                        <p class="level-subtitle">{{ user_current_level.name }}</p>
                    </div>
                    <a href="{{ path('level') }}" class="btn-guide">GUIDE</a>
                </div>
            {% else %}
                <div class="info-card">
                    <p>Aucun niveau actif trouvé pour ce parcours.</p>
                </div>
            {% endif %}

            <div class="level-container">

                {% set lesson_count = 0 %}
                {% set challenge_count = 0 %}
                {% set middle_index = (events_of_level|length / 2)|round(0, 'ceil') %}

                <div class="level-section section-left-mascot">
                    <div class="mascot-wrapper">
                        <img src="{{ user_current_level.mascot1 }}" alt="Mascotte guide">
                    </div>

                    <div class="events-wrapper">
                        {% for event in events_of_level|slice(0, middle_index) %}

                            {% if event.eventType.value == "défi" %}
                                {% set challenge_count = challenge_count + 1 %}
                                {% set current_number = challenge_count %}
                            {% else %}
                                {% set lesson_count = lesson_count + 1 %}
                                {% set current_number = lesson_count %}
                            {% endif %}

                            {#
                            Curve path layout calculation:
                            Computes a dynamic horizontal pixel offset (--x-offset) based on the item's
                            distance from the middle of the list to arrange buttons in a curved timeline.
                            #}
                            {% set total = loop.length %}
                            {% set mid = (total - 1) / 2 %}
                            {% set dist = (loop.index0 - mid)|abs %}
                            {% set x_offset = mid > 0 ? 25 - (80 * dist / mid) : 15 %}

                            {% if event.sequenceNumber > user_current_event.sequenceNumber %}
                                <span class="event-btn locked" style="--x-offset: {{ x_offset }}px;">
                                    <img src="{{ asset('/uploads/icons/lock.svg') }}"
                                         alt=""
                                         class="btn-icon">
                                    {{ event.eventType.value }} {{ current_number }}
                                </span>
                            {% else %}
                                <a href="{{ path('event', {'uid': event.uid, 'pageNumber': 1}) }}"
                                   class="event-btn {{ user_current_event == event ? 'current-event' : '' }}
                                        {{ event.eventType.value == "défi" ? 'btn-primary-golden' : 'btn-primary-green' }}"
                                   style="--x-offset: {{ x_offset }}px;">
                                    {% if event.eventType.value == "défi" %}
                                        <img src="{{ asset('/uploads/icons/challenge.svg') }}" alt="" class="btn-icon">
                                    {% else %}
                                        <img src="{{ asset('/uploads/icons/lesson.svg') }}" alt="" class="btn-icon">
                                    {% endif %}
                                    {{ event.eventType.value }} {{ current_number }}
                                </a>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>

                <div class="level-tip">
                    <p><strong>Astuce : </strong>{{ user_current_level.tip.content }}</p>
                </div>

                <div class="level-section section-right-mascot">
                    <div class="events-wrapper">
                        {% for event in events_of_level|slice(middle_index) %}

                            {% if event.eventType.value == "défi" %}
                                {% set challenge_count = challenge_count + 1 %}
                                {% set current_number = challenge_count %}
                            {% else %}
                                {% set lesson_count = lesson_count + 1 %}
                                {% set current_number = lesson_count %}
                            {% endif %}

                            {#
                            Curve path layout calculation:
                            Computes a dynamic horizontal pixel offset (--x-offset) based on the item's
                            distance from the middle of the list to arrange buttons in a curved timeline.
                            #}
                            {% set total = loop.length %}
                            {% set mid = (total - 1) / 2 %}
                            {% set dist = (loop.index0 - mid)|abs %}
                            {% set x_offset = mid > 0 ? 25 - (80 * dist / mid) : 15 %}

                            {% if event.sequenceNumber > user_current_event.sequenceNumber %}
                                <span class="event-btn locked" style="--x-offset: {{ -x_offset }}px;">
                                    <img src="{{ asset('/uploads/icons/lock.svg') }}" alt="" class="btn-icon">
                                    {{ event.eventType.value }} {{ current_number }}
                                </span>
                            {% else %}
                                <a href="{{ path('event', {'uid': event.uid, 'pageNumber': 1}) }}"
                                   class="event-btn {{ user_current_event == event ? 'current-event' : '' }}
                                                 {{ event.eventType.value == "défi" ? 'btn-primary-golden' : 'btn-primary-green' }}"
                                   style="--x-offset: {{ -x_offset }}px;"
                                >
                                    {% if event.eventType.value == "défi" %}
                                        <img src="{{ asset('/uploads/icons/challenge.svg') }}" alt="" class="btn-icon">
                                    {% else %}
                                        <img src="{{ asset('/uploads/icons/lesson.svg') }}" alt="" class="btn-icon">
                                    {% endif %}
                                    {{ event.eventType.value }} {{ current_number }}
                                </a>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <div class="mascot-wrapper">
                        <img src="{{ user_current_level.mascot2 }}" alt="Mascotte célébration">
                    </div>
                </div>

            </div>

            <div class="next-level-section">
                <span class="next-level-badge">À suivre</span>

                {% if next_level is not null %}
                    <div class="next-level-card">
                        <div class="next-level-info">
                            <h3>Niveau {{ next_level.sequenceNumber }}</h3>
                            <p>{{ next_level.name }}</p>
                        </div>
                        <div class="next-level-icon">
                            <img src="{{ asset('/uploads/icons/lock.svg') }}" alt="">
                        </div>
                    </div>
                {% else %}
                    <div class="success-card">
                        <p>Tu as atteint la fin du parcours !</p>
                    </div>
                {% endif %}
            </div>

        {% endif %}

        <div class="future-feature-card">

            <h2>Bientôt : Des Parcours Sur-Mesure</h2>

            <p>Parce que chaque éco-citoyen est différent,
                un quiz d'évaluation initial vous sera bientôt proposé à l'inscription.
                Il nous permettra de vous orienter vers le parcours d'accompagnement
                le plus adapté à votre mode de vie.</p>

        </div>
    </main>

{% endblock %}
