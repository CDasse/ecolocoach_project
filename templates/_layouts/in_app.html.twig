{% extends 'base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset("styles/header.css") }}"/>
    <link rel="stylesheet" href="{{ asset("styles/footer.css") }}"/>
    <link rel="stylesheet" href="{{ asset("styles/path.css") }}"/>
    <link rel="stylesheet" href="{{ asset("styles/event.css") }}"/>
    <link rel="stylesheet" href="{{ asset("styles/impact.css") }}"/>
    <link rel="stylesheet" href="{{ asset("styles/popup-challenge.css") }}"/>
    <link rel="stylesheet" href="{{ asset("styles/modal-feedback.css") }}"/>
{% endblock %}

{% block body %}

    <header>
        {% block header_title %}{% endblock %}

        <nav aria-label="Menu principal">
            <button class="open-menu-button"
                    type="button"
                    aria-haspopup="dialog"
                    aria-label="Ouvrir le menu principal"
                    aria-controls="dialog-burger-menu">
                <img src="{{ asset("/uploads/icons/burger_menu.svg") }}" alt="">
            </button>
        </nav>

        <dialog aria-modal="true" id="dialog-burger-menu">
            <button class="exit-menu-button"
                    type="button"
                    aria-label="Fermer le menu">
                <img src="{{ asset("/uploads/icons/cross.svg") }}" alt="">
            </button>

            {% include "_components/menu.html.twig" %}
        </dialog>

    </header>

    {% include '_components/_flash_messages.html.twig' %}

    {% block content %}{% endblock %}

    {% include "_components/_footer.html.twig" %}

{% endblock %}
