{% set all_flashes = app.flashes %}
{% set target_types = ['success',
    'info',
    'challenge_accepted',
    'challenge_refused',
    'level_up'] %}
{% set has_modals = false %}

{% for type, messages in all_flashes %}
    {% if type in target_types and messages is not empty %}
        {% set has_modals = true %}
    {% endif %}
{% endfor %}

{% if has_modals %}
    <dialog id="flash-dialog"
            class="feedback-dialog"
            aria-modal="true">

        <button type="button"
                id="flash-close-btn"
                class="modal-close-cross"
                aria-label="Fermer la modale">
            <img src="{{ asset('/uploads/icons/cross.svg') }}"
                 alt="">
        </button>

        <section class="modal-feedback-box">
            {% for type, messages in all_flashes %}
                {% if type in target_types %}
                    {% for message in messages %}

                        <p class="modal-feedback-text">
                            {{ message|sanitize_html }}
                        </p>

                        {% if type in ['challenge_accepted', 'challenge_refused'] %}
                            <a href="{{ path('recap_challenges') }}"
                               class="btn-primary btn-primary-green">
                                Voir tous mes défis
                            </a>
                        {% endif %}

                        {% if type == 'level_up' %}
                            <img src="{{ asset('/uploads/mascots/manchot_3.webp') }}"
                                 alt=""
                                 class="flash-illustration">
                        {% endif %}

                    {% endfor %}
                {% endif %}
            {% endfor %}
        </section>
    </dialog>
{% endif %}
