{% extends '_layouts/standard.html.twig' %}

{% block title %}Connexion | EcoloCoach{% endblock %}

{% block content %}
    <div class="auth-page-container">
        <div class="auth-card">
            <h1>Connexion</h1>

            <form method="post" class="auth-form">
                {% if error %}
                    <div class="auth-alert-error">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                {% if app.user %}
                    <div class="already-connected-section">
                        <p>Tu es connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>.</p>
                        <a href="{{ logout_path() }}">Se déconnecter</a>
                    </div>
                {% endif %}

                <div class="form-group">
                    <label for="username">Email</label>
                    <input type="email" value="{{ last_username }}" name="_username" id="username" class="auth-input"
                           autocomplete="email" required autofocus>
                </div>

                <div class="form-group">
                    <label for="password">Mot de passe</label>
                    <input type="password" name="_password" id="password" class="auth-input"
                           autocomplete="current-password" required>
                </div>

                <input type="hidden" name="_csrf_token" data-controller="csrf-protection"
                       value="{{ csrf_token('authenticate') }}">

                <button class="btn-primary btn-primary-green" type="submit">
                    Se connecter
                </button>

                <div class="register-section">
                    <p>Pas encore de compte ?</p>
                    <a href="{{ path("app_register") }}" class="btn-secondary btn-secondary-green">
                        S'inscrire
                    </a>
                </div>
            </form>
        </div>
    </div>
{% endblock %}
